{
  "name": "@rdmr-eu/sparql-query-runner",
  "version": "7.0.6",
  "description": "Run SPARQL queries serially on a SPARQL endpoint.",
  "main": "dist/cli/cli.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/redmer/sparql-query-runner.git"
  },
  "bugs": {
    "url": "https://github.com/redmer/sparql-query-runner/issues"
  },
  "author": "Redmer Kronemeijer <12477216+redmer@users.noreply.github.com> (https://rdmr.eu/)",
  "license": "MPL-2.0",
  "private": false,
  "bin": {
    "sparql-query-runner": "dist/cli/cli.js"
  },
  "scripts": {
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:ci": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --ci --runInBand --testTimeout=120000",
    "test:ci:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --ci --coverage --runInBand --testTimeout=120000",
    "build": "tsc -p ./tsconfig.json",
    "watch": "tsc --watch -p ./tsconfig.json",
    "lint": "cross-env ESLINT_STRICT=true ESLINT_EXPENSIVE=true eslint .",
    "prepare": "npm run build",
    "preversion": "npm run lint",
    "postversion": "git push && git push --tags"
  },
  "files": [
    "dist/**/*"
  ],
  "types": "dist",
  "type": "module",
  "devDependencies": {
    "@comunica/types": "^5.3.0",
    "@rdfjs/types": "^2.0.1",
    "@types/jest": "^30.0.0",
    "@types/json-stable-stringify": "^1.1.0",
    "@types/n3": "^1.26.1",
    "@types/node": "^22.13.1",
    "@types/rdf-validate-shacl": "^0.4.9",
    "@types/rdfjs__serializer-turtle": "^1.1.0",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "eslint-config-eslint": "^14.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.5",
    "jest": "^30.4.2",
    "lint-staged": "^17.1.1",
    "prettier": "^3.9.6",
    "ts-jest": "^29.4.12",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  },
  "lint-staged": {
    "*.ts?(x)": [
      "prettier --parser typescript --write",
      "npm run lint",
      "npm test --findRelatedTests"
    ],
    "*.json": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ],
    "*.yml": [
      "prettier --write"
    ]
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testMatch": [
      "**/(*.)+test\\.ts"
    ],
    "moduleDirectories": [
      "node_modules",
      "src"
    ],
    "roots": [
      "src",
      "test"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "\\.[tj]sx?$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "tsconfig.test.json",
          "diagnostics": false
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(@rdfjs|@comunica|n3|rdf-.*|shacl-engine|rdf-validate-shacl|hylar-core|readable-stream-node-to-web|stream-chunks|readable-to-string)/)"
    ],
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.test.ts",
      "!src/**/*.d.ts",
      "!src/type-defs/**",
      "!src/config/schema-types.ts",
      "!src/parts/triplydb.ts",
      "!src/parts/laces-hub.ts",
      "!src/parts/sparql-update-endpoint.ts",
      "!src/parts/sparql-graph-store.ts",
      "!src/parts/sparql-quad-store.ts",
      "!src/parts/download-file.ts",
      "!src/parts/shell.ts",
      "!src/parts/comunica-auto-source.ts",
      "!src/utils/download-remote.ts",
      "!src/utils/laces.ts",
      "!src/utils/auth-proxy-handler.ts",
      "!src/utils/uploading-message.ts",
      "!src/utils/report.ts",
      "!src/cli/cli.ts"
    ]
  },
  "prettier": {
    "printWidth": 100
  },
  "dependencies": {
    "@comunica/logger-pretty": "^5.3.0",
    "@comunica/query-sparql": "^5.3.0",
    "@rdfjs/serializer-turtle": "^1.1.5",
    "@triply/triplydb": "^9.3.5",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "glob": "^13.0.6",
    "hylar-core": "^1.2.2",
    "json-stable-stringify": "^1.3.0",
    "n3": "^2.1.1",
    "rdf-data-factory": "^2.0.2",
    "rdf-store-stream": "^3.0.0",
    "rdf-stores": "^2.0.0",
    "rdf-validate-shacl": "^0.6.5",
    "shacl-engine": "^1.1.2",
    "yaml": "^2.9.0",
    "yargs": "^18.0.0"
  }
}
